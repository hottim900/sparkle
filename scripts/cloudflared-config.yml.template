tunnel: TUNNEL_ID
credentials-file: CREDENTIALS_PATH

ingress:
  # Route all traffic through Cloudflare Tunnel.
  # Access control is handled by Cloudflare Access — see docs/cloudflare-access-setup.md
  - hostname: YOUR_HOSTNAME
    service: http://localhost:3000
    # Plain HTTP is recommended when using Cloudflare Tunnel — both processes
    # share localhost, so TLS adds overhead with no security benefit.
    # For direct LAN access with HTTPS, change to:
    #   service: https://localhost:3000
    #   originRequest:
    #     caPool: /path/to/mkcert/rootCA.pem
  # MCP HTTP server for Claude.ai connector (optional)
  # Requires: sparkle-mcp-http.service running on port 3001
  # DNS: add CNAME for MCP_HOSTNAME pointing to this tunnel
  # Note: do NOT put this hostname behind Cloudflare Access (Claude.ai needs direct access)
  # - hostname: MCP_HOSTNAME
  #   service: http://localhost:3001
  - service: http_status:404
